<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DF1ProgramTool.ViewModels"
        x:Class="DF1ProgramTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DF1 Program Transfer Tool"
        Width="580" Height="640"
        CanResize="True" MinWidth="500" MinHeight="500">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel Margin="10">

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#E0E0E0"
                Padding="6,4"
                CornerRadius="3"
                Margin="0,6,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" />
        </Border>

        <Grid RowDefinitions="Auto,Auto,Auto,*">

            <!-- ── Communication Settings ───────────────────────────────── -->
            <Border Grid.Row="0"
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="5"
                    Padding="10" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Communication Settings" FontWeight="Bold" Margin="0,0,0,8" />
                    <Grid ColumnDefinitions="Auto,*,Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto">

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="COM Port:"
                                   VerticalAlignment="Center" Margin="0,3,8,3" />
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   ItemsSource="{Binding AvailablePorts}"
                                   SelectedItem="{Binding SelectedPort}"
                                   HorizontalAlignment="Stretch" Margin="0,3,10,3" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Baud Rate:"
                                   VerticalAlignment="Center" Margin="0,3,8,3" />
                        <ComboBox  Grid.Row="0" Grid.Column="3"
                                   ItemsSource="{Binding BaudRates}"
                                   SelectedItem="{Binding SelectedBaud}"
                                   HorizontalAlignment="Stretch" Margin="0,3,0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Checksum:"
                                   VerticalAlignment="Center" Margin="0,3,8,3" />
                        <ComboBox  Grid.Row="1" Grid.Column="3"
                                   ItemsSource="{Binding ChecksumOptions}"
                                   SelectedItem="{Binding SelectedChecksum}"
                                   HorizontalAlignment="Stretch" Margin="0,3,0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Parity:"
                                   VerticalAlignment="Center" Margin="0,3,8,3" />
                        <ComboBox  Grid.Row="1" Grid.Column="1"
                                   ItemsSource="{Binding ParityOptions}"
                                   SelectedItem="{Binding SelectedParity}"
                                   HorizontalAlignment="Stretch" Margin="0,3,10,3" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Target Node:"
                                   VerticalAlignment="Center" Margin="0,3,8,3" />
                        <NumericUpDown Grid.Row="2" Grid.Column="3"
                                       Value="{Binding TargetNode}"
                                       Minimum="0" Maximum="31" Increment="1"
                                       FormatString="0"
                                       HorizontalAlignment="Stretch" Margin="0,3,0,3" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="My Node:"
                                   VerticalAlignment="Center" Margin="0,3,8,3" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding MyNode}"
                                       Minimum="0" Maximum="31" Increment="1"
                                       FormatString="0"
                                       HorizontalAlignment="Stretch" Margin="0,3,10,3" />
                        <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Spacing="6"
                                    HorizontalAlignment="Right" Margin="0,6,0,0">
                            <Button Content="Refresh"
                                    Command="{Binding RefreshPortsCommand}" />
                            <Button Content="Connect"
                                    Command="{Binding ConnectCommand}"
                                    IsVisible="{Binding !IsConnected}" />
                            <Button Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    IsVisible="{Binding IsConnected}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Program Transfer ─────────────────────────────────────── -->
            <Border Grid.Row="1"
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="5"
                    Padding="10" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Program Transfer" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Content="Upload  (PLC → File)"
                                Command="{Binding UploadCommand}"
                                IsEnabled="{Binding CanUpload}"
                                Width="170"
                                Background="#2E7D32"
                                Foreground="White"
                                BorderThickness="0" />
                        <Button Content="Compare"
                                Command="{Binding CompareCommand}"
                                IsEnabled="{Binding CanCompare}"
                                Width="170"
                                Background="#1565C0"
                                Foreground="White"
                                BorderThickness="0" />
                        <Button Content="Download  (File → PLC)"
                                Command="{Binding DownloadCommand}"
                                IsEnabled="{Binding CanDownload}"
                                Width="170"
                                Background="#C62828"
                                Foreground="White"
                                BorderThickness="0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Progress ─────────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="5"
                    Padding="10" Margin="0,0,0,6">
                <StackPanel Spacing="5">
                    <TextBlock Text="Progress" FontWeight="Bold" />
                    <ProgressBar Value="{Binding ProgressValue}"
                                 Minimum="0" Maximum="100" Height="16" />
                    <TextBlock Text="{Binding ProgressMessage}"
                               FontSize="11" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ── Log ──────────────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="5"
                    Padding="10">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,5">
                        <TextBlock Text="Log" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <Button Content="Clear"
                                Command="{Binding ClearLogCommand}"
                                HorizontalAlignment="Right"
                                Padding="8,2" FontSize="11" />
                    </DockPanel>
                    <!-- x:Name so code-behind can scroll to end on update -->
                    <TextBox x:Name="LogTextBox"
                             Text="{Binding LogText}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="11"
                             BorderThickness="0" />
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
