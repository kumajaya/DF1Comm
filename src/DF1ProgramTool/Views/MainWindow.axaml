<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DF1ProgramTool.ViewModels"
        x:Class="DF1ProgramTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DF1 Program Transfer Tool"
        Width="560" Height="460"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#E0E0E0"
                Padding="6,4"
                CornerRadius="3"
                Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" />
        </Border>

        <StackPanel Spacing="10">

            <!-- ── Communication Settings ───────────────────────────────── -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="Communication Settings" FontWeight="Bold" Margin="0,0,0,8" />

                    <Grid ColumnDefinitions="Auto,*,Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Row 0: COM Port | Baud Rate -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="COM Port:"
                                   VerticalAlignment="Center" Margin="0,4,8,4" />
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   ItemsSource="{Binding AvailablePorts}"
                                   SelectedItem="{Binding SelectedPort}"
                                   HorizontalAlignment="Stretch" Margin="0,4,12,4" />

                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="Baud Rate:"
                                   VerticalAlignment="Center" Margin="0,4,8,4" />
                        <ComboBox  Grid.Row="0" Grid.Column="3"
                                   ItemsSource="{Binding BaudRates}"
                                   SelectedItem="{Binding SelectedBaud}"
                                   HorizontalAlignment="Stretch" Margin="0,4,0,4" />

                        <!-- Row 1: Parity | Target Node -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Parity:"
                                   VerticalAlignment="Center" Margin="0,4,8,4" />
                        <ComboBox  Grid.Row="1" Grid.Column="1"
                                   ItemsSource="{Binding ParityOptions}"
                                   SelectedItem="{Binding SelectedParity}"
                                   HorizontalAlignment="Stretch" Margin="0,4,12,4" />

                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="Target Node:"
                                   VerticalAlignment="Center" Margin="0,4,8,4" />
                        <!-- NumericUpDown.Value is decimal? in Avalonia -->
                        <NumericUpDown Grid.Row="1" Grid.Column="3"
                                       Value="{Binding TargetNode}"
                                       Minimum="0" Maximum="31" Increment="1"
                                       FormatString="0"
                                       HorizontalAlignment="Stretch" Margin="0,4,0,4" />

                        <!-- Row 2: My Node -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="My Node:"
                                   VerticalAlignment="Center" Margin="0,4,8,4" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding MyNode}"
                                       Minimum="0" Maximum="31" Increment="1"
                                       FormatString="0"
                                       HorizontalAlignment="Stretch" Margin="0,4,12,4" />

                        <!-- Row 3: Action buttons -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                                    Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                            <Button Content="Refresh Ports"
                                    Command="{Binding RefreshPortsCommand}" />
                            <Button Content="Connect"
                                    Command="{Binding ConnectCommand}"
                                    IsVisible="{Binding !IsConnected}" />
                            <Button Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    IsVisible="{Binding IsConnected}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Program Transfer ─────────────────────────────────────── -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="Program Transfer" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Content="Upload  (PLC → File)"
                                Command="{Binding UploadCommand}"
                                IsEnabled="{Binding CanUpload}"
                                Width="170" />
                        <Button Content="Download  (File → PLC)"
                                Command="{Binding DownloadCommand}"
                                IsEnabled="{Binding CanDownload}"
                                Width="170" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Progress ─────────────────────────────────────────────── -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="Progress" FontWeight="Bold" />
                    <ProgressBar Value="{Binding ProgressValue}"
                                 Minimum="0" Maximum="100"
                                 Height="18" />
                    <TextBlock Text="{Binding ProgressMessage}"
                               TextAlignment="Center"
                               FontSize="11" />
                </StackPanel>
            </Border>

            <!-- ── Info ──────────────────────────────────────────────────── -->
            <TextBlock Text="Supports SLC 5/01–5/05, MicroLogix 1000/1500"
                       FontSize="11" Opacity="0.55"
                       HorizontalAlignment="Center" />

        </StackPanel>
    </DockPanel>
</Window>
